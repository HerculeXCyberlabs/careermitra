# CareerMitra crawler — copy to .env and adjust. No secrets belong here (R14).

# Politeness & legal (be a good citizen — these are government public sites)
CRAWLER_USER_AGENT="CareerMitraBot/0.1 (+https://careermitra.in/bot; contact@careermitra.in)"
CRAWLER_REQUEST_DELAY_MS=3000
CRAWLER_RESPECT_ROBOTS=true

# Local storage (the JSON store for this proof; Postgres comes later behind the same interface)
CM_DATA_DIR=./data
