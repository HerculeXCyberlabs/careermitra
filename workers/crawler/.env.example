# CareerMitra crawler — copy to .env and adjust. No secrets belong here (R14).

# Politeness & legal (be a good citizen — these are government public sites)
CRAWLER_USER_AGENT="CareerMitraBot/0.1 (+https://careermitra.in/bot; contact@careermitra.in)"
CRAWLER_REQUEST_DELAY_MS=3000
CRAWLER_RESPECT_ROBOTS=true

# Resilience (S021) — gov sites are slow and often ship incomplete TLS chains
CRAWLER_REQUEST_TIMEOUT_MS=20000
CRAWLER_MAX_RETRIES=2
# Only reads public HTML, sends no credentials — safe to tolerate broken .gov.in cert chains
CRAWLER_ALLOW_INSECURE_TLS=false

# Field extraction (S027) — fetch each notice's detail page/PDF for dates/vacancies (slower)
CRAWLER_FETCH_DETAILS=false

# Storage backend (S030): 'json' = local file (default), 'pg' = Postgres (docker compose up -d)
CM_STORE=json
CM_DATA_DIR=./data
DATABASE_URL=postgres://cm:cm_dev_pw@localhost:5439/careermitra
